{
  "name": "@anthropic-ai/hatch-backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=node --external @electric-sql/pglite --external drizzle-orm/pglite",
    "start": "bun run dist/index.js",
    "db:generate": "bun x drizzle-kit generate",
    "db:migrate": "bun x drizzle-kit migrate",
    "db:push": "bun x drizzle-kit push"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.3",
    "drizzle-orm": "^0.39.3",
    "hono": "^4.6.0",
    "jose": "^6.0.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
